{
  "manifest_version": 3,
  "name": "Fortune Tracker",
  "version": "1.1",
  "description": "自動取得 Fortune Music Cookie 並同步抽選記錄",
  "key": "",
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "https://fortune-music.vercel.app/*",
      "https://fortunemusic.vercel.app/*"
    ]
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://fortunemusic.jp/*",
    "https://ticket.fortunemeets.app/*",
    "https://ticket-api.fortunemeets.app/*",
    "http://localhost:8080/*",
    "https://fortunemusictracker.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Fortune Tracker"
  }
}
